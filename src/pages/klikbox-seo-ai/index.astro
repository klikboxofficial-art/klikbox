---
import KlikboxSeoAiLayout from "../../layouts/KlikboxSeoAiLayout.astro";
---
<KlikboxSeoAiLayout
  title="Klikbox SEO AI - Shopify product SEO optimizer"
  description="Klikbox SEO AI helps Shopify merchants audit product SEO fields and generate reviewable AI drafts for product copy."
>
  <section class="hero">
    <div>
      <p class="eyebrow">Shopify product SEO workflow</p>
      <h1>Audit product SEO and draft cleaner product copy with AI.</h1>
      <p class="lead">
        Klikbox SEO AI helps Shopify merchants find missing or weak product SEO fields,
        generate draft improvements, review the copy, and apply approved updates.
      </p>
      <div class="actions">
        <a class="button primary" href="/klikbox-seo-ai/support/">Contact support</a>
        <a class="button secondary" href="/klikbox-seo-ai/privacy/">Read privacy policy</a>
      </div>
    </div>
    <a class="hero-shot" href="/klikbox-seo-ai/01-dashboard-overview.png">
      <img src="/klikbox-seo-ai/01-dashboard-overview.png" alt="Klikbox SEO AI dashboard overview" />
    </a>
  </section>

  <section class="section">
    <h2>What the app helps with</h2>
    <div class="grid cols-3">
      <article class="card">
        <h3>Catalog audit</h3>
        <p>
          Review product SEO scores, missing SEO titles, missing meta descriptions,
          and thin product descriptions from one queue.
        </p>
      </article>
      <article class="card">
        <h3>AI draft workflow</h3>
        <p>
          Generate draft SEO titles, meta descriptions, and product descriptions,
          then review the copy before publishing changes.
        </p>
      </article>
      <article class="card">
        <h3>Brand voice controls</h3>
        <p>
          Set tone, audience, keyword guidance, and blocked claims so product copy
          stays consistent across the catalog.
        </p>
      </article>
    </div>
  </section>

  <section class="section">
    <h2>Product screenshots</h2>
    <div class="grid cols-2">
      <article class="screenshot-card">
        <img src="/klikbox-seo-ai/02-ai-draft-preview.png" alt="AI draft preview screen" />
        <div>
          <h3>Review before applying</h3>
          <p>Merchants can edit generated copy before updating a product.</p>
        </div>
      </article>
      <article class="screenshot-card">
        <img src="/klikbox-seo-ai/03-bulk-drafts.png" alt="Batch draft screen" />
        <div>
          <h3>Small batch cleanup</h3>
          <p>Create drafts for selected products and apply them one by one.</p>
        </div>
      </article>
      <article class="screenshot-card">
        <img src="/klikbox-seo-ai/04-brand-voice.png" alt="Brand voice profile screen" />
        <div>
          <h3>Brand voice profile</h3>
          <p>Guide AI output with tone, audience, keyword rules, and claim guardrails.</p>
        </div>
      </article>
      <article class="screenshot-card">
        <img src="/klikbox-seo-ai/05-recent-drafts-usage.png" alt="Recent drafts and usage screen" />
        <div>
          <h3>Recent draft activity</h3>
          <p>Track recent draft activity and monthly draft usage.</p>
        </div>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="grid cols-2">
      <article class="card">
        <h2>Data access</h2>
        <p>
          Klikbox SEO AI currently uses product catalog permissions only:
          read_products and write_products. The app does not request protected
          customer data for its current workflow.
        </p>
      </article>
      <article class="card">
        <h2>Support</h2>
        <p>
          Need help with setup, billing, or product SEO drafts?
          Email <a href="mailto:klikboxofficial@gmail.com">klikboxofficial@gmail.com</a>.
        </p>
      </article>
    </div>
  </section>
</KlikboxSeoAiLayout>
