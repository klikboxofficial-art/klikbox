---
import KlikboxSeoAiLayout from "../../layouts/KlikboxSeoAiLayout.astro";
---
<KlikboxSeoAiLayout
  title="Support - Klikbox SEO AI"
  description="Support page for Klikbox SEO AI, a Shopify product SEO app."
>
  <section class="hero">
    <div>
      <p class="eyebrow">Support</p>
      <h1>Help for Klikbox SEO AI merchants.</h1>
      <p class="lead">
        Contact us for setup questions, billing questions, product SEO draft issues,
        or help understanding how the app updates Shopify products.
      </p>
      <div class="actions">
        <a class="button primary" href="mailto:klikboxofficial@gmail.com">Email support</a>
        <a class="button secondary" href="/klikbox-seo-ai/privacy/">Privacy policy</a>
      </div>
    </div>
    <a class="hero-shot" href="/klikbox-seo-ai/05-recent-drafts-usage.png">
      <img src="/klikbox-seo-ai/05-recent-drafts-usage.png" alt="Klikbox SEO AI usage and recent drafts screen" />
    </a>
  </section>

  <section class="section">
    <h2>Contact details</h2>
    <div class="grid cols-2">
      <article class="card">
        <h3>Email</h3>
        <p><a href="mailto:klikboxofficial@gmail.com">klikboxofficial@gmail.com</a></p>
      </article>
      <article class="card">
        <h3>Website</h3>
        <p><a href="https://klikbox.gr">https://klikbox.gr</a></p>
      </article>
    </div>
  </section>

  <section class="section">
    <h2>Support topics</h2>
    <div class="grid cols-3">
      <article class="card">
        <h3>Installation</h3>
        <p>Help installing the app and opening it from Shopify Admin.</p>
      </article>
      <article class="card">
        <h3>SEO drafts</h3>
        <p>Help generating, reviewing, editing, and applying product SEO drafts.</p>
      </article>
      <article class="card">
        <h3>Billing</h3>
        <p>Help with Shopify Billing approvals, plan changes, and monthly draft limits.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <h2>Frequently asked questions</h2>
    <div class="grid">
      <article class="card">
        <h3>Does the app publish changes automatically?</h3>
        <p>No. The app generates draft copy first. Product updates are applied only after the merchant approves a draft.</p>
      </article>
      <article class="card">
        <h3>Does the app need customer data?</h3>
        <p>No. The current workflow uses product catalog data and does not request protected customer data.</p>
      </article>
      <article class="card">
        <h3>Can I edit AI copy before applying it?</h3>
        <p>Yes. Draft SEO titles, meta descriptions, and product descriptions can be reviewed and edited before applying.</p>
      </article>
    </div>
  </section>
</KlikboxSeoAiLayout>
