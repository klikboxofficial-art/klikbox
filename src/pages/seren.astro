<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Seren— Beauty & Cosmetics</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Tenor+Sans&family=Lato:wght@200;300;400&display=swap" rel="stylesheet">
<style>
:root {
  --cream: #faf7f2;
  --nude: #e8ddd0;
  --nude-dark: #d4c4b0;
  --gold: #c9a96e;
  --gold-light: #e0c48a;
  --gold-dark: #a07840;
  --brown: #5c3d2e;
  --text: #2a1f14;
  --text-muted: #8a7060;
  --white: #fff;
  --black: #1a1208;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Lato', sans-serif;
  background: var(--cream);
  color: var(--text);
  overflow-x: hidden;
}

nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding: 20px 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.4s ease;
}
nav.scrolled {
  background: rgba(250,247,242,0.97);
  backdrop-filter: blur(12px);
  padding: 14px 60px;
  box-shadow: 0 1px 0 rgba(0,0,0,0.06);
}
.nav-logo {
  font-family: 'Playfair Display', serif;
  font-size: 24px;
  font-weight: 400;
  letter-spacing: 0.06em;
  color: var(--white);
  text-decoration: none;
  transition: color 0.3s;
}
nav.scrolled .nav-logo { color: var(--text); }
.nav-menu { display: flex; gap: 40px; list-style: none; }
.nav-menu a {
  font-size: 11px; font-weight: 300; letter-spacing: 0.2em;
  text-transform: uppercase; color: rgba(255,255,255,0.85);
  text-decoration: none; transition: color 0.3s;
}
nav.scrolled .nav-menu a { color: var(--text-muted); }
.nav-menu a:hover { color: var(--gold) !important; }
.nav-actions { display: flex; align-items: center; gap: 20px; }
.nav-icon { font-size: 18px; color: rgba(255,255,255,0.85); cursor: pointer; transition: color 0.3s; position: relative; }
nav.scrolled .nav-icon { color: var(--text-muted); }
.nav-icon:hover { color: var(--gold) !important; }
.cart-count { position: absolute; top: -6px; right: -6px; background: var(--gold); color: white; font-size: 9px; width: 16px; height: 16px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }

.hero { position: relative; height: 100vh; min-height: 700px; display: grid; grid-template-columns: 1fr 1fr; overflow: hidden; }
.hero-left { background: var(--black); display: flex; align-items: flex-end; padding: 0 80px 80px; position: relative; overflow: hidden; }
.hero-left::before { content: ''; position: absolute; inset: 0; background: url('https://images.unsplash.com/photo-1596462502278-27bfdc403348?w=900&q=80') center/cover; opacity: 0.5; animation: heroZoom 18s ease-in-out infinite alternate; }
@keyframes heroZoom { from { transform: scale(1.02); } to { transform: scale(1.08); } }
.hero-left-content { position: relative; z-index: 2; }
.hero-eyebrow { font-size: 10px; letter-spacing: 0.35em; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; display: flex; align-items: center; gap: 12px; animation: fadeUp 1s 0.3s both; }
.hero-eyebrow::before { content: ''; width: 32px; height: 1px; background: var(--gold); }
.hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(48px, 5vw, 72px); font-weight: 400; line-height: 1.05; color: var(--white); margin-bottom: 24px; animation: fadeUp 1s 0.5s both; }
.hero h1 em { font-style: italic; color: var(--gold-light); }
.hero-sub { font-size: 14px; font-weight: 200; color: rgba(255,255,255,0.6); line-height: 1.9; max-width: 360px; margin-bottom: 40px; animation: fadeUp 1s 0.7s both; }
.hero-cta { display: flex; gap: 16px; animation: fadeUp 1s 0.9s both; flex-wrap: wrap; }
.btn-gold { display: inline-block; padding: 15px 36px; background: var(--gold); color: white; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 400; text-decoration: none; font-family: 'Lato', sans-serif; transition: all 0.3s; border: none; cursor: pointer; }
.btn-gold:hover { background: var(--gold-dark); }
.btn-outline-white { display: inline-block; padding: 15px 36px; background: transparent; color: white; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 400; text-decoration: none; font-family: 'Lato', sans-serif; border: 1px solid rgba(255,255,255,0.3); transition: all 0.3s; }
.btn-outline-white:hover { border-color: var(--gold); color: var(--gold); }
.hero-right { background: var(--nude); position: relative; overflow: hidden; }
.hero-right img { width: 100%; height: 100%; object-fit: cover; opacity: 0.9; }
.hero-right-badge { position: absolute; top: 48px; left: -20px; background: var(--gold); color: white; padding: 16px 24px 16px 40px; font-family: 'Playfair Display', serif; font-size: 13px; font-style: italic; }

.marquee-wrap { background: var(--gold); padding: 14px 0; overflow: hidden; white-space: nowrap; }
.marquee-track { display: inline-flex; animation: marquee 20s linear infinite; }
@keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
.marquee-item { font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase; color: white; font-weight: 300; padding: 0 40px; display: inline-flex; align-items: center; gap: 16px; }
.marquee-item::after { content: '✦'; font-size: 8px; opacity: 0.6; }

section { padding: 100px 60px; }
.section-eyebrow { font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; display: flex; align-items: center; gap: 12px; font-weight: 400; }
.section-eyebrow::before { content: ''; width: 28px; height: 1px; background: var(--gold); }
.section-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 56px; max-width: 1400px; margin-left: auto; margin-right: auto; }
h2 { font-family: 'Playfair Display', serif; font-size: clamp(32px, 4vw, 48px); font-weight: 400; line-height: 1.15; color: var(--text); }
h2 em { font-style: italic; color: var(--gold-dark); }
.view-all { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); text-decoration: none; border-bottom: 1px solid var(--nude-dark); padding-bottom: 2px; transition: all 0.3s; font-weight: 300; }
.view-all:hover { color: var(--gold); border-color: var(--gold); }

.categories-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; grid-template-rows: 320px 320px; gap: 3px; max-width: 1400px; margin: 0 auto; }
.cat-card { position: relative; overflow: hidden; cursor: pointer; }
.cat-card:first-child { grid-row: span 2; }
.cat-card img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s ease; filter: brightness(0.85); }
.cat-card:hover img { transform: scale(1.06); filter: brightness(0.75); }
.cat-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(26,18,8,0.7) 0%, transparent 60%); display: flex; align-items: flex-end; padding: 28px; }
.cat-name { font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 400; color: white; margin-bottom: 4px; }
.cat-count { font-size: 11px; letter-spacing: 0.15em; color: rgba(255,255,255,0.55); text-transform: uppercase; }

.products-section { background: var(--white); }
.products-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; max-width: 1400px; margin: 56px auto 0; }
.product-card { background: var(--cream); cursor: pointer; position: relative; overflow: hidden; }
.product-img-wrap { position: relative; overflow: hidden; aspect-ratio: 3/4; }
.product-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
.product-card:hover .product-img-wrap img { transform: scale(1.05); }
.product-badge { position: absolute; top: 16px; left: 16px; background: var(--gold); color: white; font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; padding: 5px 10px; }
.product-badge.new { background: var(--brown); }
.product-actions { position: absolute; bottom: -60px; left: 0; right: 0; padding: 0 20px 20px; transition: bottom 0.3s ease; display: flex; gap: 8px; }
.product-card:hover .product-actions { bottom: 0; }
.btn-add-cart { flex: 1; padding: 12px; background: var(--text); color: white; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; border: none; cursor: pointer; font-family: 'Lato', sans-serif; font-weight: 300; transition: background 0.3s; }
.btn-add-cart:hover { background: var(--gold); }
.btn-wishlist { width: 44px; background: white; border: none; cursor: pointer; font-size: 16px; transition: background 0.3s; display: flex; align-items: center; justify-content: center; }
.product-info { padding: 20px; }
.product-brand { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 6px; }
.product-name { font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 400; color: var(--text); margin-bottom: 8px; line-height: 1.3; }
.product-price { font-size: 15px; font-weight: 300; color: var(--gold-dark); }
.product-price .original { text-decoration: line-through; color: var(--text-muted); font-size: 13px; margin-right: 8px; }
.product-stars { font-size: 11px; color: var(--gold); letter-spacing: 2px; margin-bottom: 4px; }

.banner { display: grid; grid-template-columns: 1fr 1fr; min-height: 500px; }
.banner-left { background: var(--black); position: relative; overflow: hidden; }
.banner-left img { width: 100%; height: 100%; object-fit: cover; opacity: 0.6; }
.banner-right { background: var(--nude); display: flex; flex-direction: column; justify-content: center; padding: 80px; }
.btn-dark { display: inline-block; padding: 15px 36px; background: var(--text); color: white; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 300; text-decoration: none; font-family: 'Lato', sans-serif; transition: background 0.3s; border: none; cursor: pointer; }
.btn-dark:hover { background: var(--gold); }

.bestsellers-list { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; max-width: 1400px; margin: 56px auto 0; background: var(--nude-dark); }
.bestseller-item { background: var(--cream); display: grid; grid-template-columns: 100px 1fr; cursor: pointer; transition: background 0.3s; }
.bestseller-item:hover { background: var(--white); }
.bestseller-img { width: 100px; height: 120px; object-fit: cover; }
.bestseller-info { padding: 20px; display: flex; flex-direction: column; justify-content: center; }
.bestseller-num { font-family: 'Playfair Display', serif; font-size: 32px; color: var(--nude-dark); line-height: 1; margin-bottom: 8px; }
.bestseller-name { font-family: 'Playfair Display', serif; font-size: 16px; color: var(--text); margin-bottom: 4px; }
.bestseller-brand { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px; }
.bestseller-price { font-size: 14px; color: var(--gold-dark); font-weight: 300; }

.testimonials-section { background: var(--black); position: relative; overflow: hidden; }
.testimonials-section::before { content: '"'; position: absolute; font-family: 'Playfair Display', serif; font-size: 400px; color: rgba(201,169,110,0.06); top: -40px; left: 40px; line-height: 1; pointer-events: none; }
.testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; max-width: 1400px; margin: 56px auto 0; background: rgba(255,255,255,0.06); }
.testimonial-card { background: var(--black); padding: 48px 40px; transition: background 0.3s; }
.testimonial-card:hover { background: rgba(255,255,255,0.03); }
.t-stars { color: var(--gold); font-size: 13px; letter-spacing: 3px; margin-bottom: 24px; }
.t-text { font-family: 'Playfair Display', serif; font-size: 18px; font-style: italic; color: rgba(255,255,255,0.85); line-height: 1.7; margin-bottom: 28px; }
.t-author { display: flex; align-items: center; gap: 14px; }
.t-avatar { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; border: 1px solid rgba(201,169,110,0.3); }
.t-name { font-size: 14px; font-weight: 300; color: rgba(255,255,255,0.7); }
.t-handle { font-size: 11px; color: var(--gold); letter-spacing: 0.1em; }

.newsletter { background: var(--nude); text-align: center; }
.newsletter-form { display: flex; max-width: 480px; margin: 32px auto 0; }
.newsletter-form input { flex: 1; padding: 16px 24px; background: white; border: 1px solid var(--nude-dark); border-right: none; font-family: 'Lato', sans-serif; font-size: 14px; font-weight: 200; color: var(--text); outline: none; }
.newsletter-form button { padding: 16px 32px; background: var(--gold); color: white; border: none; font-family: 'Lato', sans-serif; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; transition: background 0.3s; }
.newsletter-form button:hover { background: var(--gold-dark); }

footer { background: var(--text); padding: 72px 60px 32px; }
.footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 60px; max-width: 1400px; margin: 0 auto; padding-bottom: 56px; border-bottom: 1px solid rgba(255,255,255,0.07); margin-bottom: 32px; }
.footer-logo { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 400; color: white; margin-bottom: 16px; }
.footer-tagline { font-size: 13px; font-weight: 200; color: rgba(255,255,255,0.35); line-height: 1.9; max-width: 240px; margin-bottom: 28px; }
.footer-col h4 { font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; font-family: 'Lato', sans-serif; font-weight: 400; }
.footer-col ul { list-style: none; }
.footer-col ul li { margin-bottom: 10px; }
.footer-col ul li a { font-size: 13px; font-weight: 200; color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.2s; }
.footer-col ul li a:hover { color: white; }
.footer-bottom { max-width: 1400px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
.footer-bottom p { font-size: 12px; font-weight: 200; color: rgba(255,255,255,0.2); }
.footer-bottom a { color: var(--gold); text-decoration: none; }

@keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
.reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.8s ease, transform 0.8s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }

@media (max-width: 1024px) {
  nav { padding: 20px 32px; }
  nav.scrolled { padding: 14px 32px; }
  .hero { grid-template-columns: 1fr; }
  .hero-right { display: none; }
  .hero-left { min-height: 100vh; }
  .categories-grid { grid-template-columns: 1fr 1fr; }
  .cat-card:first-child { grid-row: span 1; }
  .products-grid { grid-template-columns: 1fr 1fr; }
  .banner { grid-template-columns: 1fr; }
  .banner-left { height: 300px; }
  .bestsellers-list { grid-template-columns: 1fr; }
  .testimonials-grid { grid-template-columns: 1fr; }
  .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  section { padding: 70px 32px; }
  footer { padding: 60px 32px 32px; }
}
@media (max-width: 768px) {
  .nav-menu { display: none; }
  .products-grid { grid-template-columns: 1fr 1fr; }
  .footer-grid { grid-template-columns: 1fr; }
  .banner-right { padding: 48px 32px; }
  .hero-left { padding: 0 32px 64px; }
  .section-header { flex-direction: column; align-items: flex-start; gap: 16px; }
}
</style>
</head>
