---
---

<html lang="el">
<head>
<link rel="icon" type="image/png" href="/favicon.png" />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>KlikBox — Web Development & AI Solutions</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #0a0f1e;
      --navy2: #0d1529;
      --orange: #f97316;
      --orange-dim: rgba(249,115,22,0.12);
      --muted: rgba(255,255,255,0.55);
      --card: rgba(255,255,255,0.04);
      --card-border: rgba(255,255,255,0.08);
    }
    html { scroll-behavior: smooth; }
    body { background: var(--navy); color: #fff; font-family: 'Inter', sans-serif; overflow-x: hidden; }

    nav { display: flex; align-items: center; justify-content: space-between; padding: 20px 48px; border-bottom: 0.5px solid var(--card-border); position: fixed; top: 0; width: 100%; background: rgba(10,15,30,0.85); backdrop-filter: blur(12px); z-index: 100; }
    .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .logo img { height: 72px; }
    .nav-links { display: flex; gap: 32px; }
    .nav-links a { color: var(--muted); text-decoration: none; font-size: 14px; transition: color 0.2s; }
    .nav-links a:hover { color: #fff; }
    .lang-switch { display: flex; gap: 6px; }
 	.lang-switch button { background: none; border: 0.5px solid var(--card-border); padding: 5px 8px; border-radius: 6px; cursor: pointer; opacity: 0.5; transition: all 0.2s; display: flex; align-items: center; }
	.lang-switch button.active { border-color: var(--orange); opacity: 1; }
	.lang-switch button img { display: block; width: 24px; height: 18px; }

    .hero-wrap { position: relative; height: 100vh; display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .hero-bg { position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 60%, rgba(249,115,22,0.08) 0%, transparent 70%), radial-gradient(ellipse at 80% 20%, rgba(59,130,246,0.06) 0%, transparent 60%); will-change: transform; }
    .hero-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 60px 60px; will-change: transform; }
    .hero-content { position: relative; text-align: center; padding: 0 24px; }
    .badge { display: inline-block; background: var(--orange-dim); color: var(--orange); font-size: 12px; padding: 5px 14px; border-radius: 20px; border: 0.5px solid rgba(249,115,22,0.3); margin-bottom: 24px; }
    .hero h1 { font-size: 64px; font-weight: 600; line-height: 1.1; letter-spacing: -2px; margin-bottom: 20px; }
    .hero h1 span { color: var(--orange); }
    .hero p { font-size: 17px; color: var(--muted); max-width: 500px; margin: 0 auto 36px; line-height: 1.7; }
    .hero-btns { display: flex; gap: 12px; justify-content: center; }
    .btn-primary { background: var(--orange); color: #fff; border: none; padding: 13px 30px; border-radius: 8px; font-size: 15px; font-weight: 500; cursor: pointer; font-family: inherit; transition: opacity 0.2s, transform 0.2s; }
    .btn-primary:hover { opacity: 0.85; transform: translateY(-1px); }
    .btn-ghost { background: transparent; color: var(--muted); border: 0.5px solid var(--card-border); padding: 13px 30px; border-radius: 8px; font-size: 15px; cursor: pointer; font-family: inherit; transition: all 0.2s; }
    .btn-ghost:hover { color: #fff; border-color: rgba(255,255,255,0.3); transform: translateY(-1px); }
    .scroll-indicator { position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; color: var(--muted); font-size: 20px; animation: bounce 2s infinite; }

    .stats-section { padding: 80px 48px; position: relative; z-index: 1; background: rgba(10,15,30,0.7); backdrop-filter: blur(10px); }
    .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; max-width: 900px; margin: 0 auto; }
    .stat { background: var(--card); border: 0.5px solid var(--card-border); border-radius: 12px; padding: 28px 20px; text-align: center; transition: border-color 0.3s, transform 0.3s; }
    .stat:hover { border-color: rgba(249,115,22,0.3); transform: translateY(-4px); }
    .stat-num { font-size: 36px; font-weight: 600; color: var(--orange); }
    .stat-label { font-size: 13px; color: var(--muted); margin-top: 6px; }

    .services-section { padding: 80px 48px; background: rgba(13,21,41,0.92); backdrop-filter: blur(10px); position: relative; z-index: 1; }
    .section-header { text-align: center; margin-bottom: 48px; }
    .section-label { font-size: 11px; text-transform: uppercase; letter-spacing: 2px; color: var(--orange); margin-bottom: 12px; }
    .section-title { font-size: 36px; font-weight: 600; letter-spacing: -0.5px; }
    .section-title span { color: var(--orange); }
    .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; max-width: 1100px; margin: 0 auto; }
    .service-card { background: var(--card); border: 0.5px solid var(--card-border); border-radius: 16px; padding: 32px; transition: all 0.3s; position: relative; overflow: hidden; }
    .service-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--orange); transform: scaleX(0); transition: transform 0.3s; transform-origin: left; }
    .service-card:hover::before { transform: scaleX(1); }
    .service-card:hover { border-color: rgba(249,115,22,0.2); transform: translateY(-6px); }
    .service-icon { font-size: 36px; margin-bottom: 16px; }
    .service-card h3 { font-size: 18px; font-weight: 500; margin-bottom: 10px; }
    .service-card p { font-size: 14px; color: var(--muted); line-height: 1.7; }

    .projects-section { padding: 80px 48px; }
    .projects-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; max-width: 1100px; margin: 0 auto; }
    .project-card { background: var(--card); border: 0.5px solid var(--card-border); border-radius: 16px; padding: 28px; transition: all 0.3s; cursor: pointer; }
    .project-card:hover { border-color: rgba(249,115,22,0.4); transform: translateY(-6px); }
    .project-card-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 16px; }
    .card-tag { font-size: 11px; color: var(--orange); background: var(--orange-dim); padding: 4px 12px; border-radius: 20px; border: 0.5px solid rgba(249,115,22,0.2); }
    .card-arrow { color: var(--muted); font-size: 18px; transition: all 0.2s; }
    .project-card:hover .card-arrow { color: var(--orange); transform: translate(3px,-3px); }
    .project-card h3 { font-size: 18px; font-weight: 500; margin-bottom: 10px; }
    .project-card p { font-size: 14px; color: var(--muted); line-height: 1.7; margin-bottom: 20px; }
    .card-footer { display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--muted); padding-top: 16px; border-top: 0.5px solid var(--card-border); }
    .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--orange); flex-shrink: 0; }
    .dot.live { animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

    .about-section { padding: 80px 48px; background: var(--navy2); }
    .about-inner { max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
    .about-text .section-label { text-align: left; }
    .about-text h2 { font-size: 36px; font-weight: 600; letter-spacing: -0.5px; margin-bottom: 20px; line-height: 1.2; }
    .about-text h2 span { color: var(--orange); }
    .about-text p { font-size: 15px; color: var(--muted); line-height: 1.8; margin-bottom: 16px; }
    .about-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 24px; }
    .tag { background: var(--orange-dim); color: var(--orange); font-size: 12px; padding: 5px 14px; border-radius: 20px; border: 0.5px solid rgba(249,115,22,0.2); }
    .about-visual { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .about-box { background: var(--card); border: 0.5px solid var(--card-border); border-radius: 12px; padding: 24px; text-align: center; transition: all 0.3s; }
    .about-box:hover { border-color: rgba(249,115,22,0.3); transform: scale(1.03); }
    .about-box-num { font-size: 28px; font-weight: 600; color: var(--orange); }
    .about-box-label { font-size: 12px; color: var(--muted); margin-top: 4px; }

    .contact-section { padding: 80px 48px; }
    .contact-inner { max-width: 700px; margin: 0 auto; background: var(--card); border: 0.5px solid var(--card-border); border-radius: 24px; padding: 60px; text-align: center; position: relative; overflow: hidden; }
    .contact-inner::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 0%, rgba(249,115,22,0.06) 0%, transparent 70%); pointer-events: none; }
    .contact-inner .section-label { margin-bottom: 16px; }
    .contact-inner h2 { font-size: 36px; font-weight: 600; margin-bottom: 16px; }
    .contact-inner h2 span { color: var(--orange); }
    .contact-inner p { color: var(--muted); font-size: 16px; margin-bottom: 32px; line-height: 1.7; }

    footer { border-top: 0.5px solid var(--card-border); padding: 24px 48px; display: flex; justify-content: space-between; align-items: center; }
    footer p { font-size: 13px; color: var(--muted); }
    footer span { color: var(--orange); font-size: 13px; }

    .fade-in { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .fade-in.visible { opacity: 1; transform: translateY(0); }
    .fade-in-delay-1 { transition-delay: 0.1s; }
    .fade-in-delay-2 { transition-delay: 0.2s; }
    .fade-in-delay-3 { transition-delay: 0.3s; }

    @media (max-width: 768px) {
      nav { padding: 16px 20px; }
      .nav-links { display: none; }
      .hero h1 { font-size: 36px; letter-spacing: -1px; }
      .stats { grid-template-columns: repeat(2, 1fr); }
      .stats-section, .services-section, .projects-section, .about-section, .contact-section { padding: 60px 20px; }
      .about-inner { grid-template-columns: 1fr; gap: 40px; }
      .contact-inner { padding: 40px 24px; }
      footer { padding: 16px 20px; flex-direction: column; gap: 8px; text-align: center; }
	  .fi { display: none; }
    }
  </style>
</head>
<body>

<canvas id="c" style="position:fixed;top:0;left:0;z-index:0;pointer-events:none;"></canvas>
<nav>
  <a class="logo" href="/">
    <img src="/favicon.png" alt="KlikBox" />
  </a>
  <div class="nav-links">
    <a href="#services" data-gr="Υπηρεσίες" data-en="Services">Υπηρεσίες</a>
    <a href="#projects" data-gr="Projects" data-en="Projects">Projects</a>
    <a href="#about" data-gr="Σχετικά" data-en="About">Σχετικά</a>
    <a href="#contact" data-gr="Επικοινωνία" data-en="Contact">Επικοινωνία</a>
  </div>
  <div class="lang-switch">
    <button class="active" onclick="setLang('gr')" title="Ελληνικά">
    <img src="https://flagcdn.com/24x18/gr.png" alt="GR" />
  </button>
  <button onclick="setLang('en')" title="English">
    <img src="https://flagcdn.com/24x18/gb.png" alt="EN" />
  </button>
  </div>
</nav>

<!-- HERO -->
<section class="hero-wrap">
  <div class="hero-bg" id="parallax-bg"></div>
  <div class="hero-grid" id="parallax-grid"></div>

  

  <div class="hero-content">
    <div class="badge">Web Development & AI Solutions</div>
    <div class="hero">
      <h1 id="hero-title">Δημιουργούμε<br><span>ψηφιακές εμπειρίες</span><br>που ξεχωρίζουν</h1>
      <p id="hero-sub">Websites, web apps και AI-powered εφαρμογές για επιχειρήσεις που θέλουν να ξεχωρίσουν στο διαδίκτυο.</p>
      <div class="hero-btns">
        <button class="btn-primary" id="btn-projects" onclick="document.getElementById('projects').scrollIntoView({behavior:'smooth'})">Δες τα Projects →</button>
        <button class="btn-ghost" id="btn-contact" onclick="document.getElementById('contact').scrollIntoView({behavior:'smooth'})">Επικοινωνία</button>
      </div>
    </div>
  </div>
  <div class="scroll-indicator">↓</div>
</section>
<section class="stats-section">
  <div class="stats">
    <div class="stat fade-in">
      <div class="stat-num">12+</div>
      <div class="stat-label" id="stat1">Projects Ολοκληρωμένα</div>
    </div>
    <div class="stat fade-in fade-in-delay-1">
      <div class="stat-num">3</div>
      <div class="stat-label" id="stat2">AI Εφαρμογές</div>
    </div>
    <div class="stat fade-in fade-in-delay-2">
      <div class="stat-num">5+</div>
      <div class="stat-label" id="stat3">Χρόνια Εμπειρίας</div>
    </div>
    <div class="stat fade-in fade-in-delay-3">
      <div class="stat-num">100%</div>
      <div class="stat-label" id="stat4">Ικανοποιημένοι Πελάτες</div>
    </div>
  </div>
</section>

<section class="services-section" id="services">
  <div class="section-header fade-in">
    <div class="section-label" id="services-label">— Τι Προσφέρουμε</div>
    <h2 class="section-title" id="services-title">Υπηρεσίες που <span>φέρνουν αποτελέσματα</span></h2>
  </div>
  <div class="services-grid">
    <div class="service-card fade-in">
      <div class="service-icon">🌐</div>
      <h3 id="s1-title">Web Development</h3>
      <p id="s1-desc">Κατασκευή επαγγελματικών websites με WordPress, custom HTML/CSS και modern frameworks.</p>
    </div>
    <div class="service-card fade-in fade-in-delay-1">
      <div class="service-icon">🤖</div>
      <h3 id="s2-title">AI Solutions</h3>
      <p id="s2-desc">Claude-powered εφαρμογές και εργαλεία που αυτοματοποιούν διαδικασίες και εξοικονομούν χρόνο.</p>
    </div>
    <div class="service-card fade-in fade-in-delay-2">
      <div class="service-icon">⚡</div>
      <h3 id="s3-title">Web Apps</h3>
      <p id="s3-desc">Custom web applications με real-time δυνατότητες, dashboards και σύγχρονα UI/UX.</p>
    </div>
    <div class="service-card fade-in fade-in-delay-3">
      <div class="service-icon">🎨</div>
      <h3 id="s4-title">UI/UX Design</h3>
      <p id="s4-desc">Σχεδιασμός interfaces που εντυπωσιάζουν και μετατρέπουν επισκέπτες σε πελάτες.</p>
    </div>
  </div>
</section>

<section class="projects-section" id="projects">
  <div class="section-header fade-in">
    <div class="section-label" id="projects-label">— Δουλειά μας</div>
    <h2 class="section-title">Featured <span>Projects</span></h2>
  </div>
  <div class="projects-grid">
    <div class="project-card fade-in" onclick="window.open('https://sunrisehouse.gr','_blank')">
      <div class="project-card-top">
        <div class="card-tag">WordPress</div>
        <div class="card-arrow">↗</div>
      </div>
      <h3>Sunrise House</h3>
      <p id="p1-desc">Vacation rental site για την Πάργα με multilingual support (GR/EN/SR), parallax effects και lightbox gallery.</p>
      <div class="card-footer"><div class="dot live"></div>sunrisehouse.gr</div>
    </div>
    <div class="project-card fade-in fade-in-delay-1" onclick="window.open('https://klikbox.gr/levante/','_blank')">
      <div class="project-card-top">
        <div class="card-tag">WordPress / WooCommerce</div>
        <div class="card-arrow">↗</div>
      </div>
      <h3 id="p2-title">Levante</h3>
      <p id="p2-desc">Luxury vacation rental site για ενοικιαζόμενα στο Ιόνιο με multilingual support (EN/GR/SR) και online booking.</p>
      <div class="card-footer"><div class="dot live"></div>klikbox.gr/levante</div>
    </div>
    <div class="project-card fade-in fade-in-delay-2" onclick="window.open('https://klikbox.gr','_blank')">
      <div class="project-card-top">
        <div class="card-tag">Astro / Three.js</div>
        <div class="card-arrow">↗</div>
      </div>
      <h3 id="p3-title">KlikBox Portfolio</h3>
      <p id="p3-desc">Portfolio site με 3D hero, floating tech icons, parallax effects και multilingual support (GR/EN).</p>
      <div class="card-footer"><div class="dot live"></div>klikbox.gr</div>
    </div>
  </div>
</section>

<section class="about-section" id="about">
  <div class="about-inner">
    <div class="about-text fade-in">
      <div class="section-label" id="about-label">— Σχετικά με μας</div>
      <h2 id="about-title">Φτιάχνουμε digital προϊόντα που <span>λειτουργούν</span></h2>
      <p id="about-p1">Η KlikBox είναι ένα creative digital studio που συνδυάζει modern web development με AI τεχνολογία για να δημιουργεί εξαιρετικές ψηφιακές εμπειρίες.</p>
      <p id="about-p2">Από απλά επαγγελματικά websites μέχρι σύνθετες AI-powered εφαρμογές — κάθε project παραδίδεται με προσοχή στη λεπτομέρεια και στόχο τα αποτελέσματα.</p>
      <div class="about-tags">
        <span class="tag">WordPress</span>
        <span class="tag">Astro</span>
        <span class="tag">Claude AI</span>
        <span class="tag">React</span>
        <span class="tag">UI/UX</span>
        <span class="tag">SEO</span>
      </div>
    </div>
    <div class="about-visual fade-in fade-in-delay-1">
      <div class="about-box">
        <div class="about-box-num">12+</div>
        <div class="about-box-label" id="ab1">Projects</div>
      </div>
      <div class="about-box">
        <div class="about-box-num">3</div>
        <div class="about-box-label" id="ab2">AI Apps</div>
      </div>
      <div class="about-box">
        <div class="about-box-num">5+</div>
        <div class="about-box-label" id="ab3">Χρόνια</div>
      </div>
      <div class="about-box">
        <div class="about-box-num">∞</div>
        <div class="about-box-label" id="ab4">Δημιουργικότητα</div>
      </div>
    </div>
  </div>
</section>

<section class="contact-section" id="contact">
  <div class="contact-inner fade-in">
    <div class="section-label" id="contact-label">— Επικοινωνία</div>
    <h2 id="contact-title">Ας <span>συνεργαστούμε</span></h2>
    <p id="contact-desc">Έχεις ένα project στο μυαλό σου; Είμαστε εδώ για να το κάνουμε πραγματικότητα. Στείλε μας μήνυμα και θα επικοινωνήσουμε μαζί σου σύντομα.</p>
    <a href="mailto:klikboxofficial@gmail.com"><button class="btn-primary" id="contact-btn">Στείλε μήνυμα →</button></a>
  </div>
</section>

<footer>
  <p>© 2026 KlikBox. <span id="footer-rights">Όλα τα δικαιώματα κατοχυρωμένα.</span></p>
  <span>klikbox.gr</span>
</footer>

<script is:inline>
  const canvas3d = document.getElementById('c');
const renderer = new THREE.WebGLRenderer({ canvas: canvas3d, antialias: true, alpha: true });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.setSize(window.innerWidth, window.innerHeight);
const scene = new THREE.Scene();
const camera3d = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
camera3d.position.z = 30;
const count = 6000;
const positions = new Float32Array(count * 3);
const colors = new Float32Array(count * 3);
const orange = new THREE.Color('#f97316');
const blue = new THREE.Color('#3b82f6');
const white = new THREE.Color('#ffffff');
for (let i = 0; i < count; i++) {
  const i3 = i * 3;
  const r = 20 + Math.random() * 10;
  const theta = Math.random() * Math.PI * 2;
  const phi = Math.acos(2 * Math.random() - 1);
  positions[i3] = r * Math.sin(phi) * Math.cos(theta);
  positions[i3+1] = r * Math.sin(phi) * Math.sin(theta);
  positions[i3+2] = r * Math.cos(phi);
  const mix = Math.random();
  const c = mix < 0.3 ? orange : mix < 0.5 ? blue : white;
  colors[i3] = c.r; colors[i3+1] = c.g; colors[i3+2] = c.b;
}
const geo = new THREE.BufferGeometry();
geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
geo.setAttribute('color', new THREE.BufferAttribute(colors, 3));
const mat = new THREE.PointsMaterial({ size: 0.15, vertexColors: true, transparent: true, opacity: 0.5 });
const particles = new THREE.Points(geo, mat);
scene.add(particles);
const torusGeo = new THREE.TorusGeometry(8, 0.3, 16, 100);
const torusMat = new THREE.MeshBasicMaterial({ color: 0xf97316, transparent: true, opacity: 0.15 });
const torus = new THREE.Mesh(torusGeo, torusMat);
scene.add(torus);
const torus2Geo = new THREE.TorusGeometry(12, 0.15, 16, 100);
const torus2Mat = new THREE.MeshBasicMaterial({ color: 0x3b82f6, transparent: true, opacity: 0.08 });
const torus2 = new THREE.Mesh(torus2Geo, torus2Mat);
torus2.rotation.x = Math.PI / 3;
scene.add(torus2);
const icoGeo = new THREE.IcosahedronGeometry(3, 1);
const icoMat = new THREE.MeshBasicMaterial({ color: 0xf97316, wireframe: true, transparent: true, opacity: 0.2 });
const ico = new THREE.Mesh(icoGeo, icoMat);
scene.add(ico);
let mouseX3d = 0, mouseY3d = 0;
document.addEventListener('mousemove', e => {
  mouseX3d = (e.clientX / window.innerWidth - 0.5) * 2;
  mouseY3d = -(e.clientY / window.innerHeight - 0.5) * 2;
});
window.addEventListener('resize', () => {
  camera3d.aspect = window.innerWidth / window.innerHeight;
  camera3d.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
});
const clock = new THREE.Clock();
function animate3d() {
  requestAnimationFrame(animate3d);
  const t = clock.getElapsedTime();
  particles.rotation.y = t * 0.04 + mouseX3d * 0.3;
  particles.rotation.x = t * 0.02 + mouseY3d * 0.2;
  torus.rotation.x = t * 0.3;
  torus.rotation.y = t * 0.2 + mouseX3d * 0.5;
  torus2.rotation.z = t * 0.15;
  torus2.rotation.y = t * 0.1 + mouseY3d * 0.3;
  ico.rotation.x = t * 0.5;
  ico.rotation.y = t * 0.3;
  ico.scale.setScalar(1 + Math.sin(t * 2) * 0.05);
  camera3d.position.x += (mouseX3d * 3 - camera3d.position.x) * 0.05;
  camera3d.position.y += (mouseY3d * 2 - camera3d.position.y) * 0.05;
  camera3d.lookAt(scene.position);
  renderer.render(scene, camera3d);
}
animate3d();
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    const bg = document.getElementById('parallax-bg');
    const grid = document.getElementById('parallax-grid');
    if (bg) bg.style.transform = `translateY(${y * 0.4}px)`;
    if (grid) grid.style.transform = `translateY(${y * 0.2}px)`;
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

