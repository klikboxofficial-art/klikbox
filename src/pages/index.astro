  function setLang(lang) {
    const t = translations[lang];
    Object.keys(t).forEach(id => {
      const el = document.getElementById(id);
      if (el) el.innerHTML = t[id];
    });
    const navLinks = document.querySelectorAll('.nav-links a');
    const navKeys = ['nav-services', 'nav-projects', 'nav-about', 'nav-contact'];
    navLinks.forEach((a, i) => { if (navKeys[i]) a.textContent = t[navKeys[i]]; });
    document.querySelectorAll('.lang-switch button').forEach((btn, i) => {
      btn.classList.toggle('active', (i === 0 && lang === 'gr') || (i === 1 && lang === 'en'));
    });
    document.documentElement.lang = lang === 'gr' ? 'el' : 'en';
  }
