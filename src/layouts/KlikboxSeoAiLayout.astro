---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/klikbox-seo-ai/icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg: #f4f5f7;
        --panel: #ffffff;
        --text: #111827;
        --muted: #5f6773;
        --line: #d9dee7;
        --brand: #0f766e;
        --brand-dark: #0b4d49;
        --ink: #071316;
        --soft: #e9f6f4;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.6;
      }

      a {
        color: inherit;
      }

      .site-header {
        background: rgba(255, 255, 255, 0.92);
        border-bottom: 1px solid var(--line);
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(14px);
      }

      .site-nav {
        align-items: center;
        display: flex;
        gap: 24px;
        justify-content: space-between;
        margin: 0 auto;
        max-width: 1120px;
        padding: 14px 20px;
      }

      .brand-link {
        align-items: center;
        display: inline-flex;
        gap: 10px;
        font-weight: 700;
        text-decoration: none;
      }

      .brand-link img {
        border-radius: 7px;
        height: 28px;
        width: 28px;
      }

      .nav-links {
        align-items: center;
        display: flex;
        gap: 18px;
        font-size: 14px;
      }

      .nav-links a {
        color: var(--muted);
        text-decoration: none;
      }

      .nav-links a:hover {
        color: var(--text);
      }

      .page {
        margin: 0 auto;
        max-width: 1120px;
        padding: 56px 20px 72px;
      }

      .hero {
        display: grid;
        gap: 36px;
        grid-template-columns: minmax(0, 0.9fr) minmax(420px, 1.1fr);
        align-items: center;
        padding: 26px 0 40px;
      }

      .eyebrow {
        color: var(--brand);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.08em;
        margin: 0 0 14px;
        text-transform: uppercase;
      }

      h1 {
        font-size: 52px;
        letter-spacing: 0;
        line-height: 1.05;
        margin: 0;
      }

      h2 {
        font-size: 28px;
        letter-spacing: 0;
        line-height: 1.2;
        margin: 0 0 18px;
      }

      h3 {
        font-size: 18px;
        margin: 0 0 8px;
      }

      p {
        margin: 0 0 16px;
      }

      .lead {
        color: var(--muted);
        font-size: 18px;
        margin-top: 20px;
        max-width: 620px;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 28px;
      }

      .button {
        align-items: center;
        border-radius: 8px;
        display: inline-flex;
        font-weight: 700;
        justify-content: center;
        min-height: 44px;
        padding: 11px 18px;
        text-decoration: none;
      }

      .button.primary {
        background: var(--ink);
        color: #ffffff;
      }

      .button.secondary {
        background: var(--panel);
        border: 1px solid var(--line);
        color: var(--text);
      }

      .hero-shot {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 12px;
        box-shadow: 0 18px 50px rgba(17, 24, 39, 0.1);
        display: block;
        overflow: hidden;
      }

      .hero-shot img,
      .screenshot-card img {
        display: block;
        height: auto;
        width: 100%;
      }

      .section {
        padding: 42px 0;
      }

      .grid {
        display: grid;
        gap: 16px;
      }

      .grid.cols-3 {
        grid-template-columns: repeat(3, 1fr);
      }

      .grid.cols-2 {
        grid-template-columns: repeat(2, 1fr);
      }

      .card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 10px;
        padding: 22px;
      }

      .card p,
      .legal-card p,
      .legal-card li {
        color: var(--muted);
      }

      .screenshot-card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 10px;
        overflow: hidden;
      }

      .screenshot-card div {
        padding: 16px;
      }

      .legal-page {
        display: grid;
        gap: 18px;
        grid-template-columns: minmax(0, 1fr) 280px;
        align-items: start;
      }

      .legal-card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 10px;
        padding: 28px;
      }

      .legal-card h2 {
        font-size: 22px;
        margin-top: 8px;
      }

      .legal-card ul {
        margin: 0 0 16px;
        padding-left: 20px;
      }

      .aside {
        background: var(--soft);
        border: 1px solid #c8e7e2;
        border-radius: 10px;
        padding: 20px;
        position: sticky;
        top: 84px;
      }

      .meta {
        color: var(--muted);
        font-size: 14px;
      }

      .site-footer {
        border-top: 1px solid var(--line);
        color: var(--muted);
        font-size: 14px;
        padding: 28px 20px;
        text-align: center;
      }

      @media (max-width: 860px) {
        .site-nav {
          align-items: flex-start;
          flex-direction: column;
        }

        .nav-links {
          flex-wrap: wrap;
        }

        .hero,
        .legal-page {
          grid-template-columns: 1fr;
        }

        .grid.cols-3,
        .grid.cols-2 {
          grid-template-columns: 1fr;
        }

        h1 {
          font-size: 38px;
        }

        .page {
          padding-top: 34px;
        }

        .aside {
          position: static;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a class="brand-link" href="/klikbox-seo-ai/">
          <img src="/klikbox-seo-ai/icon.png" alt="Klikbox SEO AI icon" />
          <span>Klikbox SEO AI</span>
        </a>
        <div class="nav-links" aria-label="Main navigation">
          <a href="/klikbox-seo-ai/">Product</a>
          <a href="/klikbox-seo-ai/privacy/">Privacy</a>
          <a href="/klikbox-seo-ai/terms/">Terms</a>
          <a href="/klikbox-seo-ai/support/">Support</a>
          <a href="https://klikbox.gr">Klikbox.gr</a>
        </div>
      </nav>
    </header>
    <main class="page">
      <slot />
    </main>
    <footer class="site-footer">
      &copy; 2026 Klikbox. Contact: <a href="mailto:klikboxofficial@gmail.com">klikboxofficial@gmail.com</a>
    </footer>
  </body>
</html>
